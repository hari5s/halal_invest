# Variables d'environnement — Ethiq Invest AI
# Copier ce fichier en .env.local et remplir les valeurs réelles

# ── Données de marché ────────────────────────────────────────────────────────
# Polygon.io, Twelve Data, Alpha Vantage ou équivalent
MARKET_DATA_API_KEY=

# ── Actualités financières ───────────────────────────────────────────────────
# News API, Benzinga, Finnhub ou équivalent
NEWS_API_KEY=

# ── Conformité islamique ─────────────────────────────────────────────────────
# Musaffa API ou source équivalente AAOIFI
MUSAFFA_API_KEY=

# ── Intelligence artificielle ────────────────────────────────────────────────
# OpenAI (GPT-4o recommandé pour l'analyse financière)
OPENAI_API_KEY=

# ── Base de données (Phase 3) ────────────────────────────────────────────────
# PostgreSQL via Supabase, Neon ou équivalent
DATABASE_URL=

# ── Authentification (Phase 3) ───────────────────────────────────────────────
# NextAuth.js ou Clerk
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
